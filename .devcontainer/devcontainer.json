{
    "name": "Spotify Streaming Analysis",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "postCreateCommand": "cd src && python -m venv venv && ./venv/bin/pip install -r requirements.txt",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/src/venv/bin/python",
                "jupyter.notebookFileRoot": "${containerWorkspaceFolder}/src"
            }
        }
    }
}
